# ===== ClaudeSK environment — copy to .env and fill in (never commit .env) =====

# Branding (shown in sidebar, titles)
WEBUI_NAME=ClaudeSK

# Open WebUI session secret. Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-long-random-string

# Gateway admin key (used by the admin Providers page). Use a strong unique value.
GATEWAY_ADMIN_KEY=change-me-strong-admin-key

# Optional: offload embeddings to reduce Open WebUI RAM (leave blank to use local model)
RAG_EMBEDDING_ENGINE=

# Cloudflare Workers AI (only if you use that provider)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=

# Binance SOCKS5 proxy (optional, only for crypto payment verification)
BINANCE_PROXY=
